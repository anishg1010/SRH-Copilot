# Defaults are tuned for a CUDA GPU (RTX A6000). All local & free.

# ─── Embeddings (multilingual e5, GPU) ─────────────────
EMBED_PROVIDER=local
LOCAL_EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_DEVICE=            # blank = auto (cuda); or "cuda" / "cpu"
EMBED_BATCH_SIZE=64      # raise (e.g. 128/256) on the A6000 for faster ingest

# ─── Vector store (ChromaDB, local) ────────────────────
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION_PREFIX=copilot

# ─── Chunking (re-ingest after changing) ───────────────
CHUNK_TOKENS=500
CHUNK_OVERLAP=60

# ─── Retrieval ─────────────────────────────────────────
RETRIEVE_K=6
MIN_SCORE=0.0

# ─── LLM (Qwen2.5-7B in-process via transformers, GPU) ─
LLM_PROVIDER=transformers
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_DEVICE=              # blank = auto (cuda)
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# ─── Later phase (when tokens provided) ────────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
